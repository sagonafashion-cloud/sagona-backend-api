# SAGONA Mobile App — environment variables
# Copy to .env and fill in your values.
# All EXPO_PUBLIC_ vars are bundled into the app binary — never put secrets here.

EXPO_PUBLIC_API_URL=https://sagona-backend-api.onrender.com/api
EXPO_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@o0.ingest.sentry.io/0
