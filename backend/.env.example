# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/sagona

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Razorpay Configuration
# Use Razorpay test keys for development or staging, then switch to live keys in production.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=rzp_test_your_key_secret

# Server Port (optional, Render sets automatically)
PORT=5000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=https://sagona.in,https://www.sagona.in
