# ─── Core ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/sagona
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
PORT=5000
NODE_ENV=development

# ─── Admin Auth (separate from customer JWT) ─────────────
JWT_ADMIN_SECRET=your_admin_jwt_secret_different_from_jwt_secret

# ─── Razorpay ────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=rzp_test_your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Cloudinary (image + PDF storage) ───────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Nodemailer / SMTP) ───────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="SAGONA <noreply@sagona.in>"

# ─── Anthropic (AI Chatbot) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── Google Maps (admin store location picker) ───────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Shiprocket (courier integration) ───────────────────
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password

# ─── Business Rules ──────────────────────────────────────
FREE_SHIPPING_THRESHOLD=999

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=https://sagona.in,https://www.sagona.in,https://admin.sagona.in

# ─── Sentry (error monitoring) ───────────────────────────
SENTRY_DSN=https://your_sentry_dsn@o0.ingest.sentry.io/0

# ─── Support contact ─────────────────────────────────────
SUPPORT_EMAIL=care@sagona.in

# ─── SECURITY SCHEDULE ───────────────────────────────────
# JWT_SECRET          — rotate every 90 days (all users get logged out)
# JWT_ADMIN_SECRET    — rotate every 60 days
# RAZORPAY_KEY_SECRET — rotate immediately if ever exposed
# ANTHROPIC_API_KEY   — rotate immediately if ever exposed
# Last rotated: [DATE]
